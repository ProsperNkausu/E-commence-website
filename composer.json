{
    "name": "tematech/innovation",
    "type": "project",
    "require": {
        "php": "^8.1",
        "dompdf/dompdf": "^3.1",
        "laravel/framework": "^11.0",
        "phpmailer/phpmailer": "^7.0",
        "setasign/fpdf": "^1.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
